# Copy these keys into Streamlit Community Cloud:
# App → Settings → Secrets
#
# Paste as TOML (same shape as a local .streamlit/secrets.toml file).

# Required — Groq API for ChatGroq (Llama).
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional — override Chroma persist path inside the deployed repo or mounted storage.
# Default when unset: ./chroma_db next to streamlit_app.py (must exist in the deployment).
# CHROMA_PERSIST_DIR = "chroma_db"

# Optional — set to "true" only for air-gapped / pre-cached Hugging Face models (local CLI).
# On Streamlit Cloud, omit this so sentence-transformers can download the embedding model.
# HF_OFFLINE = "true"

# Optional — only for ingest.py with --groq-vision (seconds between vision calls).
# GROQ_VISION_DELAY = "2.5"
